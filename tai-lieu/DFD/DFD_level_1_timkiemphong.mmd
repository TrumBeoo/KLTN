flowchart TD
    %% External Entities
    ET1([Người thuê])
    
    %% Processes
    P1[Nhận tiêu chí tìm kiếm]
    P2[Lọc dữ liệu phòng]
    P3[Sắp xếp kết quả]
    P4[Hiển thị danh sách]
    P5[Xem chi tiết phòng]
    P6[Lưu phòng yêu thích]
    P7[Tính toán vị trí]
    
    %% Data Stores
    DS1[(DB Phòng)]
    DS2[(DB Tin đăng)]
    DS3[(DB Tiện nghi)]
    DS4[(DB Yêu thích)]
    DS5[(DB Vị trí)]
    DS6[(DB Đánh giá)]
    
    %% Flows
    ET1 -->|Tiêu chí tìm kiếm| P1
    P1 --> P2
    
    P2 --> DS1
    P2 --> DS2
    P2 --> DS3
    P2 --> DS6
    
    DS1 --> P2
    DS2 --> P2
    DS3 --> P2
    DS6 --> P2
    
    P2 --> P3
    P3 --> P4
    P4 -->|Danh sách phòng| ET1
    
    ET1 -->|Chọn phòng| P5
    P5 --> DS1
    P5 --> DS2
    P5 --> DS3
    P5 --> DS6
    
    DS1 --> P5
    DS2 --> P5
    DS3 --> P5
    DS6 --> P5
    
    P5 --> P7
    P7 --> DS5
    DS5 --> P7
    P7 -->|Chi tiết + Bản đồ| ET1
    
    ET1 -->|Lưu yêu thích| P6
    P6 --> DS4
