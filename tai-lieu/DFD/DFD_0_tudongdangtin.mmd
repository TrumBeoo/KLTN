flowchart TD
    %% Thực thể bên ngoài
    A[Chủ nhà]

    %% Quy trình chính
    B[Tự động hóa đăng tin]

    %% Kho dữ liệu
    C1[CSDL Phòng]
    C2[CSDL Tin đăng]

    %% Luồng dữ liệu từ Chủ nhà
    A -->|Upload dữ liệu phòng / tiện nghi| B

    %% Quy trình tương tác với cơ sở dữ liệu
    B -->|Lưu / cập nhật thông tin phòng| C1
