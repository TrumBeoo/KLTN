flowchart TD
    %% External Entities
    ET1([Người thuê])
    ET2([Chủ nhà])

    %% Processes
    P1[Gửi đánh giá]
    P2[Kiểm tra điều kiện đánh giá]
    P3[Xử lý và tổng hợp đánh giá]
    P4[Hiển thị đánh giá]
    P5[Kiểm duyệt nội dung]

    %% Data Stores
    DS1[(DB Đánh giá)]
    DS2[(DB Hợp đồng)]
    DS3[(DB Phòng)]

    %% Flows từ người thuê
    ET1 -->|Thông tin đánh giá| P1
    P1 --> P2
    P2 -->|Kiểm tra| DS2
    
    P2 -->|Đánh giá hợp lệ| P5
    P5 -->|Lưu đánh giá| DS1
    
    DS1 --> P3
    P3 -->|Cập nhật điểm| DS3
    
    DS1 --> P4
    DS3 --> P4
    P4 -->|Danh sách đánh giá| ET1
    P4 -->|Báo cáo đánh giá| ET2
    
    %% Kiểm duyệt
    P5 -->|Đánh giá vi phạm| ET2
